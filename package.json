{
  "name": "@eswar2000/md2x",
  "version": "0.1.2",
  "description": "Convert AI-generated Markdown into polished documents (docx today, more soon). Zero native dependencies, runs anywhere.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "markdown",
    "docx",
    "word",
    "markdown-to-docx",
    "docx-generator",
    "ooxml",
    "office",
    "convert",
    "converter",
    "pandoc-alternative",
    "table-of-contents",
    "syntax-highlighting",
    "latex",
    "math",
    "equations",
    "footnotes",
    "callouts",
    "emoji",
    "ai",
    "export",
    "document",
    "cli",
    "typescript",
    "mcp"
  ],
  "bin": {
    "md2x": "./dist/cli.js",
    "md2x-mcp": "./dist/mcp.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "docx": "^9.0.2",
    "lowlight": "^3.3.0",
    "mathml2omml": "^0.5.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gemoji": "^8.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "temml": "^0.13.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.5.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.7.4",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=18"
  }
}
